generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Game {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  status         String   @default("active") // active | finished
  playerCount    Int      @default(4) // 3 | 4
  initialPoints  Int      @default(25000)
  returnPoints   Int      @default(30000) // 返し点
  kyotaku        Int      @default(0) // 供託リーチ棒の本数
  players        GamePlayer[]
  rounds         Round[]
}

model GamePlayer {
  id       String @id @default(cuid())
  gameId   String
  name     String
  seat     Int    // 0=東, 1=南, 2=西, 3=北
  game     Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  scores   Score[]

  @@unique([gameId, seat])
}

model Round {
  id       String  @id @default(cuid())
  gameId   String
  roundNum Int     // 局番号（通し番号: 0=東1局, 1=東2局, ...）
  honba    Int     @default(0)
  game     Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  scores   Score[]

  @@unique([gameId, roundNum, honba])
}

model Score {
  id       String     @id @default(cuid())
  roundId  String
  playerId String
  points   Int        // この局での点数変動
  round    Round      @relation(fields: [roundId], references: [id], onDelete: Cascade)
  player   GamePlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([roundId, playerId])
}
